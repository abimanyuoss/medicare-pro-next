# Isi dengan connection string Neon PostgreSQL Anda
# Contoh:
# DATABASE_URL="postgresql://user:password@ep-xxx.ap-southeast-1.aws.neon.tech/neondb?sslmode=require"
DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"
AUTH_SECRET="ganti-dengan-random-string-yang-panjang"
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="ganti-password-admin"
